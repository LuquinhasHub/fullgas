# ============================================================
# Configuração da API Fullgas — copie este arquivo para ".env"
# e preencha com os seus dados. NUNCA suba o .env para o Git.
# ============================================================

# --- Conexão com o SQL Server ---
# Para a instância PADRÃO (INSTANCE NAME = MSSQLSERVER), use o host puro:
DB_SERVER=
DB_PORT=
DB_NAME=

# Autenticação do banco.
# Opção A (recomendada p/ deploy): usuário e senha do SQL Server (SQL Auth).
DB_USER=
DB_PASSWORD=
# Criptografia da conexão. Em produção use true; localmente pode ser false.
DB_ENCRYPT=false
DB_TRUST_CERT=true

# --- Servidor HTTP ---
PORT=

# Origem permitida no CORS (o endereço de onde o front é servido).
# Ex.: http://localhost:5500 (Live Server) ou https://seusite.com
CORS_ORIGIN=

# --- Segurança ---
# Chave para assinar os tokens JWT. Gere uma longa e aleatória.
JWT_SECRET=
JWT_EXPIRES=

