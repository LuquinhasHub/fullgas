# ============================================================
# Arquivos que NUNCA devem ir para o Git
# ============================================================

# Segredos e variáveis de ambiente (senhas, chaves) — CRÍTICO
.env
*.env
!.env.example
api/.env

# Dependências (são reinstaladas com npm install)
node_modules/
**/node_modules/

# Logs
*.log
npm-debug.log*

# Sistema operacional
.DS_Store
Thumbs.db

# Editores
.vscode/
.idea/
*.swp

# Uploads locais de teste (fotos de reivindicação, etc.)
uploads/
api/uploads/

# Build / temporários
dist/
tmp/
